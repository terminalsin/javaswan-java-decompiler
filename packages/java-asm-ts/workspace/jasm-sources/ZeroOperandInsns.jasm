/*
 * Test class for zero-operand instructions
 */
public class test/ZeroOperandInsns {
    // NOP instruction
    public static testNop()V {
        
        nop
        return
    }


    // ACONST_NULL instruction
    public static testAconstNull()java/lang/Object {
        
        aconst_null
        areturn
    }


    // ICONST instructions (-1 to 5)
    public static testIconstM1()I {
        
        iconst -1
        ireturn
    }


    public static testIconst0()I {
        
        iconst 0
        ireturn
    }


    public static testIconst1()I {
        
        iconst 1
        ireturn
    }


    public static testIconst2()I {
        
        iconst 2
        ireturn
    }


    public static testIconst3()I {
        
        iconst 3
        ireturn
    }


    public static testIconst4()I {
        
        iconst 4
        ireturn
    }


    public static testIconst5()I {
        
        iconst 5
        ireturn
    }


    // LCONST instructions
    public static testLconst0()J {
        
        lconst 0
        lreturn
    }


    public static testLconst1()J {
        
        lconst 1
        lreturn
    }


    // FCONST instructions
    public static testFconst0()F {
        
        fconst 0
        freturn
    }


    public static testFconst1()F {
        
        fconst 1
        freturn
    }


    public static testFconst2()F {
        
        ldc 2.0
        freturn
    }


    // DCONST instructions
    public static testDconst0()D {
        
        dconst 0
        dreturn
    }


    public static testDconst1()D {
        
        dconst 1
        dreturn
    }


    // Stack manipulation
    public static testPop(I)V {
        
        iload 0
        pop
        return
    }


    public static testPop2(J)V {
        
        lload 0
        pop2
        return
    }


    public static testDup(I)I {
        
        iload 0
        dup
        iadd
        ireturn
    }


    public static testSwap(I, I)I {
        
        iload 0
        iload 1
        swap
        isub
        ireturn
    }


    // Arithmetic instructions
    public static testIadd(I, I)I {
        
        iload 0
        iload 1
        iadd
        ireturn
    }


    public static testIsub(I, I)I {
        
        iload 0
        iload 1
        isub
        ireturn
    }


    public static testImul(I, I)I {
        
        iload 0
        iload 1
