        iload 0
        iload 1
        irem
        ireturn
    }


    public static testIneg(I)I {
        
        iload 0
        ineg
        ireturn
    }


    // Bitwise instructions
    public static testIshl(I, I)I {
        
        iload 0
        iload 1
        ishl
        ireturn
    }


    public static testIshr(I, I)I {
        
        iload 0
        iload 1
        ishr
        ireturn
    }


    public static testIushr(I, I)I {
        
        iload 0
        iload 1
        iushr
        ireturn
    }


    public static testIand(I, I)I {
        
        iload 0
        iload 1
        iand
