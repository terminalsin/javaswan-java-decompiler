        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IF_ACMPEQ instruction
    public static testIfAcmpeq(java/lang/Object, java/lang/Object)I {
        
        aload 0
        aload 1
        if_acmpeq label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFNULL instruction
    public static testIfnull(java/lang/Object)I {
        
        aload 0
        ifnull label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFNONNULL instruction
    public static testIfnonnull(java/lang/Object)I {
        
        aload 0
        ifnonnull label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // GOTO instruction
    public static testGoto()I {
        
        goto label_end
        iconst 0
        ireturn
        label_end:
        iconst 1
        ireturn
    }

}
