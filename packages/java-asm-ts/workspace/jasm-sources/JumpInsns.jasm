        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IF_ICMPEQ instruction
    public static testIfIcmpeq(I, I)I {
        
        iload 0
        iload 1
        if_icmpeq label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IF_ICMPNE instruction
    public static testIfIcmpne(I, I)I {
        
        iload 0
