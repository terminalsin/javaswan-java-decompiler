/*
 * Test class for jump instructions
 */
public class test/JumpInsns {
    // IFEQ instruction
    public static testIfeq(I)I {
        
        iload 0
        ifeq label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFNE instruction
    public static testIfne(I)I {
        
        iload 0
        ifne label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFLT instruction
    public static testIflt(I)I {
        
        iload 0
        iflt label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFGE instruction
    public static testIfge(I)I {
        
        iload 0
        ifge label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFGT instruction
    public static testIfgt(I)I {
        
        iload 0
        ifgt label_true
        iconst 0
        ireturn
        label_true:
        iconst 1
        ireturn
    }


    // IFLE instruction
    public static testIfle(I)I {
        
        iload 0
